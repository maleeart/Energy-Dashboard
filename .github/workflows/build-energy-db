name: Build Energy DB

on:
  push:
    paths:
      - "data/*.csv"
      - "scripts/build_energy_db.py"
      - ".github/workflows/build-energy-db.yml"
  workflow_dispatch:

permissions:
  contents: write

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.12"

      - name: Build JSON database
        run: python scripts/build_energy_db.py

      - name: Commit generated database
        uses: stefanzweifel/git-auto-commit-action@v5
        with:
          commit_message: "Auto-build energy database"
          file_pattern: data/energy_db.json data/validation_report.json
